{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wardline.dev/schemas/1.0/wardline.schema.json",
  "title": "Wardline Root Manifest",
  "description": "Root trust topology and governance policy for a wardline-managed project.",
  "type": "object",
  "properties": {
    "$id": {
      "type": "string",
      "description": "Schema version identifier."
    },
    "governance_profile": {
      "type": "string",
      "enum": ["lite", "assurance"],
      "description": "Declared governance profile for this deployment."
    },
    "metadata": {
      "type": "object",
      "description": "Organisational and governance metadata.",
      "properties": {
        "organisation": { "type": "string" },
        "ratified_by": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "role": { "type": "string" }
          },
          "required": ["name", "role"],
          "additionalProperties": false
        },
        "ratification_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date of ratification."
        },
        "review_interval_days": {
          "type": "integer",
          "minimum": 1
        },
        "temporal_separation": {
          "type": "object",
          "description": "Temporal separation posture declaration (§15.3.2).",
          "properties": {
            "alternative": {
              "type": "string",
              "enum": ["enforced", "same-actor-with-retrospective"],
              "description": "The declared posture: enforced or a named alternative."
            },
            "retrospective_window_days": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum days before retrospective review must occur."
            },
            "rationale": {
              "type": "string",
              "description": "Free-text justification for the alternative."
            }
          },
          "required": ["alternative"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "tiers": {
      "type": "array",
      "description": "Named tier declarations.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tier": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4
          },
          "description": { "type": "string" }
        },
        "required": ["id", "tier"],
        "additionalProperties": false
      }
    },
    "rules": {
      "type": "object",
      "description": "Rule configuration — overrides to the default severity matrix.",
      "properties": {
        "overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["OFF", "INFO", "WARNING", "ERROR", "CRITICAL"]
              }
            },
            "required": ["id", "severity"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "delegation": {
      "type": "object",
      "description": "Exception authority delegation.",
      "properties": {
        "default_authority": {
          "type": "string",
          "enum": ["NONE", "RELAXED", "STANDARD"]
        },
        "grants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "authority": {
                "type": "string",
                "enum": ["NONE", "RELAXED", "STANDARD"]
              }
            },
            "required": ["path", "authority"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "module_tiers": {
      "type": "array",
      "description": "Module-level taint defaults.",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "default_taint": {
            "type": "string",
            "enum": [
              "INTEGRAL", "ASSURED", "GUARDED",
              "EXTERNAL_RAW", "UNKNOWN_RAW",
              "UNKNOWN_GUARDED", "UNKNOWN_ASSURED",
              "MIXED_RAW"
            ]
          }
        },
        "required": ["path", "default_taint"],
        "additionalProperties": false
      }
    },
    "dependency_taint": {
      "type": "array",
      "description": "Taint declarations for third-party dependency return values.",
      "items": {
        "type": "object",
        "properties": {
          "package": {
            "type": "string",
            "description": "Package identifier with optional version constraint."
          },
          "function": {
            "type": "string",
            "description": "Fully-qualified function name (e.g. 'requests.get')."
          },
          "returns_taint": {
            "type": "string",
            "enum": [
              "INTEGRAL", "ASSURED", "GUARDED",
              "EXTERNAL_RAW", "UNKNOWN_RAW",
              "UNKNOWN_GUARDED", "UNKNOWN_ASSURED",
              "MIXED_RAW"
            ],
            "description": "Taint state of the function's return value."
          },
          "rationale": {
            "type": "string",
            "description": "Governance justification for this taint assignment."
          }
        },
        "required": ["package", "function", "returns_taint", "rationale"],
        "additionalProperties": false
      }
    },
    "overlay_paths": {
      "type": "array",
      "description": "Allowed directories for overlay discovery. Use [\"*\"] for unrestricted.",
      "items": { "type": "string" }
    },
    "max_exception_duration_days": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum allowed exception duration in days. Default: 365."
    },
    "exception_age_limits": {
      "type": "object",
      "description": "Per-exceptionability-class maximum exception duration in days.",
      "properties": {
        "STANDARD": { "type": "integer", "minimum": 1 },
        "RELAXED": { "type": "integer", "minimum": 1 },
        "TRANSPARENT": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "bootstrap_assurance_reference": {
      "type": "object",
      "description": "§15.3.4 Bootstrap Assurance Reference declaration. Present when the deployment is a reference implementation operating under the BAR sub-profile of Assurance. Consumers of this manifest MUST surface these fields for governance enforcement. The compliance ledger's bootstrap_reference_declaration block echoes these values; the manifest is the primary declaration.",
      "required": [
        "sole_maintainer",
        "declared_at",
        "graduation_target_date",
        "graduation_mechanism",
        "graduation_plan_ref",
        "slip_count"
      ],
      "properties": {
        "sole_maintainer": {
          "type": "string",
          "minLength": 1,
          "description": "Identity of the single declared human maintainer."
        },
        "declared_at": {
          "type": "string",
          "format": "date",
          "description": "Date on which BAR was first declared."
        },
        "graduation_target_date": {
          "type": "string",
          "format": "date",
          "description": "Target date for graduation out of BAR."
        },
        "graduation_mechanism": {
          "type": "string",
          "enum": ["second_maintainer", "external_audit"],
          "description": "Graduation path."
        },
        "graduation_auditor": {
          "type": "string",
          "minLength": 1,
          "description": "Named external auditor or auditing body. Required when graduation_mechanism is external_audit."
        },
        "graduation_plan_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Source reference to the written graduation plan (normally an ADR)."
        },
        "slip_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Number of graduation-date changes. §15.3.4 caps this at 2."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
